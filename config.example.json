{
  "database_path": "data/personal_brain.sqlite3",
  "memory_dir": "memory",
  "brain_index_path": "brain_index.json",
  "default_source": "cli",
  "chat_model": {
    "provider": "openai_compatible",
    "base_url": "https://api.z.ai/api/paas/v4",
    "api_key_env": "ZAI_API_KEY",
    "model": "glm-5v-turbo",
    "enabled": true,
    "timeout_seconds": 90
  }
}
